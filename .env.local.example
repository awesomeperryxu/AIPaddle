# AIPaddle 环境变量样例 —— 复制为 .env.local 后填真实值
# .env.local 已被 .gitignore 忽略，真实密钥永不进 git（ADR-001/003 铁律）

# ── Supabase（服务端访问；浏览器永不直连，见 ADR-001）──────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # 仅 lib/supabase/admin.ts 可读（ADR-002）
DATABASE_URL=postgres://<user>:<pwd>@<host>:5432/postgres

# ── 通义千问 / 百炼（LLM=Qwen + Embedding=text-embedding-v3，一家全包，ADR-003/009）──
# 一把 Key 同时供对话与嵌入；在 https://bailian.console.aliyun.com 的 API-KEY 页创建
DASHSCOPE_API_KEY=sk-<your-dashscope-key>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1536
